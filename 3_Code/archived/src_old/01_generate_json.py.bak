# -------------------------
# Utilities
# -------------------------
_JSON_FENCE_RE = re.compile(r"```(?:json)?\s*([\s\S]*?)\s*```", re.IGNORECASE)
_JSON_OBJ_RE = re.compile(r"\{[\s\S]*\}", re.MULTILINE)

def sha256_text(text: str) -> str:
    return hashlib.sha256(text.encode("utf-8")).hexdigest()

def extract_json_object(raw: str) -> Dict[str, Any]:
    raw = (raw or "").strip()
    if not raw: raise ValueError("Empty response text")
    m = _JSON_FENCE_RE.search(raw)
    if m:
        try: return json.loads(m.group(1).strip())
        except: pass
    m2 = _JSON_OBJ_RE.search(raw)
    if m2: return json.loads(m2.group(0).strip())
    try: return json.loads(raw)
    except: raise ValueError(f"Could not extract JSON from: {raw[:100]}...")

def clamp_choice(val: Any, allowed: set, default: str) -> str:
    return val if isinstance(val, str) and val in allowed else default

def to_int_0_100(x: Any, default: int = 50) -> int:
    try: return max(0, min(100, int(x)))
    except: return default

def safe_float(x: Any, default: float = 1.0) -> float:
    try: return float(x) if x is not None else default
    except: return default

def _normalize_key_text(s: str) -> str:
    return re.sub(r"\s+", " ", (s or "").strip())

def make_stable_group_id(specialty, anatomy, modality, category, split_index):
    key = f"{specialty}|{anatomy}|{modality}|{category}|{split_index}".strip()
    return hashlib.sha1(key.encode("utf-8")).hexdigest()[:16]

def weight_transform(x: float) -> float:
    x = max(0.0, float(x or 0.0))
    if WEIGHT_TRANSFORM == "LOG1P": return math.log1p(x)
    if WEIGHT_TRANSFORM == "SQRT": return math.sqrt(x)
    return math.log1p(x)

def compute_group_target_cards(group_weight_sum: float) -> int:
    w = weight_transform(group_weight_sum)
    c = round(BASE_CARDS_PER_GROUP * w) if w > 0 else MIN_CARDS_PER_GROUP
    return int(min(max(MIN_CARDS_PER_GROUP, c), MAX_CARDS_PER_GROUP))

def _ensure_table_constraints(prompt: str) -> str:
    p = (prompt or "").strip()
    if not p: return p
    if "single-page" not in p.lower(): return p.rstrip() + " " + TABLE_INFOGRAPHIC_CONSTRAINTS
    return p

def _ensure_pacs_constraints(prompt: str) -> str:
    p = (prompt or "").strip()
    if not p: return p
    if "pacs" not in p.lower(): return p.rstrip() + "\n\n" + PACS_REALISM_CONSTRAINTS
    return p

# -------------------------
# Ratio Helpers
# -------------------------
def parse_ratio_spec(spec: str, allowed_keys: set, default: Dict[str, float]) -> Dict[str, float]:
    if not spec: return dict(default)
    out = {}
    for p in spec.split(","):
        if ":" in p:
            k, v = p.split(":", 1)
            k = k.strip()
            if k in allowed_keys:
                try: out[k] = float(v)
                except: pass
    return {k: v/sum(out.values()) for k, v in out.items()} if sum(out.values()) > 0 else dict(default)

def apportion_counts(total: int, ratios: Dict[str, float]) -> Dict[str, int]:
    total = max(0, int(total))
    if total == 0: return {k: 0 for k in ratios}
    raw = {k: ratios[k] * total for k in ratios}
    base = {k: int(math.floor(v)) for k, v in raw.items()}
    rem = total - sum(base.values())
    for k in sorted(ratios, key=lambda x: raw[x]-base[x], reverse=True):
        if rem <= 0: break
        base[k] += 1
        rem -= 1
    return base

_LATEX_INLINE_DOLLAR_RE = re.compile(r"\$([^$]+)\$")
def normalize_no_latex_math(text: str) -> str:
    s = _LATEX_INLINE_DOLLAR_RE.sub(lambda m: m.group(1), text or "")
    s = s.replace("\\times", "×").replace("\\rightarrow", "→").replace("\\geq", "≥").replace("\\leq", "≤")
    return s.strip()

# -------------------------
# Validation
# -------------------------
def validate_stage1(obj: Dict[str, Any], fallback_summary: str, fallback_objectives: List[str]) -> Dict[str, Any]:
    obj = dict(obj or {})
    obj["id"] = str(obj.get("id", "")).strip() or "Unknown"
    obj["objective_summary"] = str(obj.get("objective_summary", "")).strip() or fallback_summary
    obj["group_objectives"] = [str(x).strip() for x in obj.get("group_objectives", []) if str(x).strip()] or fallback_objectives
    obj["visual_type_category"] = clamp_choice(obj.get("visual_type_category"), ALLOWED_VISUAL_TYPES, "General")
    obj["master_table_markdown_kr"] = str(obj.get("master_table_markdown_kr", "")).strip()
    obj["entity_list"] = [str(x).strip() for x in obj.get("entity_list", [])]
    obj["table_infographic_style"] = clamp_choice(obj.get("table_infographic_style"), ALLOWED_TABLE_INFOGRAPHIC_STYLES, "Default")
    
    prompt = str(obj.get("table_infographic_prompt_en", "")).strip()
    if not prompt:
        kw = str(obj.get("table_infographic_keywords_en", "")).strip() or obj["objective_summary"]
        prompt = f"Infographic of {kw}. {TABLE_INFOGRAPHIC_CONSTRAINTS}"
    obj["table_infographic_prompt_en"] = _ensure_table_constraints(prompt)
    return obj

def _build_pacs_template_from_entity(obj: Dict[str, Any]) -> str:
    name = obj.get("entity_name", "target")
    return f"Radiology image of {name}. {PACS_REALISM_CONSTRAINTS}"

def validate_stage2(obj: Dict[str, Any]) -> Dict[str, Any]:
    obj = dict(obj or {})
    obj["entity_name"] = str(obj.get("entity_name", "")).strip()
    obj["row_image_necessity"] = clamp_choice(obj.get("row_image_necessity"), ALLOWED_IMG_NECESSITY, "IMG_OPT")
    
    if obj["row_image_necessity"] == "IMG_NONE":
        obj["row_image_prompt_en"] = None
    else:
        p = str(obj.get("row_image_prompt_en", "")).strip()
        if not p: p = _build_pacs_template_from_entity(obj)
        obj["row_image_prompt_en"] = _ensure_pacs_constraints(p)

    norm_cards = []
    for c in obj.get("anki_cards", []):
        if not isinstance(c, dict): continue
        norm_cards.append({
            "card_type": clamp_choice(c.get("card_type"), ALLOWED_CARD_TYPES, "Cloze_Finding"),
            "front": normalize_no_latex_math(str(c.get("front", ""))),
            "back": normalize_no_latex_math(str(c.get("back", ""))),
            "tags": [str(t).strip() for t in c.get("tags", []) if str(t).strip()]
        })
    obj["anki_cards"] = norm_cards
    return obj

DEFAULT_CARD_RATIOS = {"Basic_QA": 0.34, "Cloze_Finding": 0.33, "MCQ_Vignette": 0.33}
DEFAULT_IMG_RATIOS = {"IMG_REQ": 0.40, "IMG_OPT": 0.40, "IMG_NONE": 0.20}
CARD_TYPE_RATIOS = parse_ratio_spec(CARD_TYPE_RATIOS_SPEC, ALLOWED_CARD_TYPES, DEFAULT_CARD_RATIOS)
IMAGE_NECESSITY_RATIOS = parse_ratio_spec(IMAGE_NECESSITY_RATIOS_SPEC, ALLOWED_IMG_NECESSITY, DEFAULT_IMG_RATIOS)

def card_type_quota_lines(cards_per_entity: int, ratios: Dict[str, float]) -> Tuple[str, Dict[str, int]]:
    quotas = apportion_counts(cards_per_entity, ratios)
    lines = "\n".join([f"- {k}: {v} card(s)" for k, v in quotas.items() if v > 0])
    return lines, quotas

def enforce_card_quota(cards, quotas):
    by_type = {}
    for c in cards: by_type.setdefault(c["card_type"], []).append(c)
    picked = []
    diag = {"picked": {}, "deficit": {}}
    
    for t, q in quotas.items():
        pool = by_type.get(t, [])
        take = min(q, len(pool))
        picked.extend(pool[:take])
        diag["picked"][t] = take
        if take < q: diag["deficit"][t] = q - take
        
    needed = sum(quotas.values())
    if len(picked) < needed:
        used = set(id(x) for x in picked)
        others = [c for c in cards if id(c) not in used]
        picked.extend(others[:needed - len(picked)])
        
    return picked[:needed], diag

def assign_image_necessity_by_ratio(entities, ratios):
    n = len(entities)
    quotas = apportion_counts(n, ratios)
    labels = []
    for k in ["IMG_REQ", "IMG_OPT", "IMG_NONE"]: labels.extend([k]*quotas.get(k, 0))
    labels = (labels + ["IMG_OPT"]*n)[:n]
    
    ranked = sorted(range(n), key=lambda i: int(entities[i].get("importance_score", 0)), reverse=True)
    counts = {k:0 for k in ratios}
    
    for rank_pos, i in enumerate(ranked):
        lab = labels[rank_pos]
        entities[i]["row_image_necessity"] = lab
        if lab == "IMG_NONE": entities[i]["row_image_prompt_en"] = None
        else:
             p = entities[i].get("row_image_prompt_en")
             if not p: p = _build_pacs_template_from_entity(entities[i])
             entities[i]["row_image_prompt_en"] = _ensure_pacs_constraints(p)
        counts[lab] += 1
    return counts

# -------------------------
# Provider Abstraction
# -------------------------
@dataclass
class ProviderClients:
    gemini_client: Optional[genai.Client] = None # Updated type for v1 SDK
    openai_client: Optional[OpenAI] = None
    deepseek_client: Optional[OpenAI] = None
    claude_client: Optional[anthropic.Anthropic] = None

def build_clients(provider: str, api_key: str) -> ProviderClients:
    clients = ProviderClients()
    if provider == "gemini":
        # [UPDATED] Initialize new GenAI Client
        clients.gemini_client = genai.Client(api_key=api_key)
    elif provider == "gpt":
        clients.openai_client = OpenAI(api_key=api_key)
    elif provider == "deepseek":
        clients.deepseek_client = OpenAI(api_key=api_key, base_url=MODEL_CONFIG["deepseek"]["base_url"])
    elif provider == "claude":
        clients.claude_client = anthropic.Anthropic(api_key=api_key)
    return clients

def _model_for_stage(provider: str, stage: int) -> str:
    default = MODEL_CONFIG[provider]["model_name"]
    if stage == 1 and TEXT_MODEL_STAGE1: return TEXT_MODEL_STAGE1
    if stage == 2 and TEXT_MODEL_STAGE2: return TEXT_MODEL_STAGE2
    return default

def call_llm(
    provider: str,
    clients: ProviderClients,
    system_prompt: str,
    user_prompt: str,
    stage: int,
    arm_config: Optional[Dict[str, Any]] = None,
    retries: int = 3,
) -> Tuple[Optional[Dict[str, Any]], Optional[str]]:
    
    # Resolve Model Name (Arm Override > Env Override > Default)
    model_name = _model_for_stage(provider, stage)
    if arm_config:
        key = "text_model_stage1" if stage == 1 else "text_model_stage2"
        if arm_config.get(key): model_name = arm_config[key]

    temperature = TEMPERATURE_STAGE1 if stage == 1 else TEMPERATURE_STAGE2
    max_tokens = MAX_TOKENS_STAGE1 if stage == 1 else MAX_TOKENS_STAGE2

    # Feature Flags
    use_thinking = arm_config.get("thinking", False) if arm_config else False
    thinking_budget = arm_config.get("thinking_budget", 0) if arm_config else 0
    use_search = arm_config.get("rag", False) if arm_config else False

    for attempt in range(retries):
        try:
            raw_text = ""

            # --- [UPDATED] Gemini Provider (v1 SDK) ---
            if provider == "gemini":
                client = clients.gemini_client
                
                # Build Config
                config = types.GenerateContentConfig(
                    temperature=temperature,
                    top_p=0.95,
                    max_output_tokens=max_tokens,
                )
                
                # Apply Thinking (Arm C, D, E)
                if use_thinking and thinking_budget > 0:
                    config.thinking_config = types.ThinkingConfig(
                        include_thoughts=True, 
                        thinking_budget=thinking_budget
                    )
                
                # Apply Search/RAG (Arm B, D)
                if use_search:
                    config.tools = [types.Tool(google_search=types.GoogleSearch())]
                    # Note: Search results usually return text, not strict JSON mime type.
                    # We remove response_mime_type restriction for Search to avoid 400 errors.
                else:
                    # Standard JSON mode (Arm A)
                    config.response_mime_type = "application/json"

                combined_prompt = f"System: {system_prompt}\n\nUser: {user_prompt}"
                
                resp = client.models.generate_content(
                    model=model_name,
                    contents=combined_prompt,
                    config=config
                )
                
                # Extract Text (Handle parts/reasoning)
                if resp.text:
                    raw_text = resp.text
                elif resp.candidates and resp.candidates[0].content.parts:
                    # Fallback for complex parts
                    raw_text = "".join([p.text for p in resp.candidates[0].content.parts if p.text])

            # --- [UPDATED] GPT Provider (OpenAI) ---
            elif provider == "gpt":
                if not clients.openai_client: return None, "Client missing"
                
                # Detect GPT-5/Reasoning Model
                is_reasoning_model = "gpt-5" in model_name or "o3" in model_name or "reasoning" in model_name

                if is_reasoning_model:
                    # Responses API (Arm F)
                    reasoning_param = {"effort": "medium"} if use_thinking else None
                    
                    resp = clients.openai_client.responses.create(
                        model=model_name,
                        instructions=system_prompt,
                        input=user_prompt,
                        reasoning=reasoning_param
                    )
                    raw_text = resp.output_text
                else:
                    # Legacy Chat API
                    resp = clients.openai_client.chat.completions.create(
                        model=model_name,
                        messages=[{"role":"system","content":system_prompt},{"role":"user","content":user_prompt}],
                        temperature=temperature,
                        top_p=0.95,
                        max_tokens=max_tokens,
                        response_format={"type": "json_object"}
                    )
                    raw_text = resp.choices[0].message.content

            # --- Other Providers (Legacy) ---
            elif provider == "deepseek":
                # ... (Logic remains same as previous) ...
                if clients.deepseek_client is None: return None, "DeepSeek client not initialized"
                resp = clients.deepseek_client.chat.completions.create(
                     model=model_name,
                     messages=[{"role":"system","content":system_prompt},{"role":"user","content":user_prompt}],
                     temperature=temperature, max_tokens=max_tokens, response_format={"type": "json_object"}
                )
                raw_text = resp.choices[0].message.content

            elif provider == "claude":
                if clients.claude_client is None: return None, "Claude client not initialized"
                resp = clients.claude_client.messages.create(
                    model=model_name, max_tokens=max_tokens, temperature=temperature, system=system_prompt,
                    messages=[{"role": "user", "content": user_prompt}]
                )
                raw_text = "\n".join([b.text for b in resp.content if getattr(b,"type","")=="text"])

            return extract_json_object(raw_text), None

        except Exception as e:
            print(f"⚠️ {provider} Error (Attempt {attempt+1}): {e}")
            time.sleep(2**attempt)

    return None, "Max retries exceeded"

# -------------------------
# Processing
# -------------------------
def norm_cell(v: Any) -> str:
    s = str(v).strip()
    return "" if s.lower() in {"nan", "null", "none", ""} else s

def parse_anki_tag_string(cell):
    return [t.lstrip("#").strip() for t in re.split(r"[|,;/\s]+", norm_cell(cell)) if t.strip()]

def build_groups(df):
    df.columns = df.columns.str.strip()
    # Simple Column Mapping (adjust if needed)
    cols = {c.lower(): c for c in df.columns}
    def get(r, k): return norm_cell(r.get(cols.get(k)))

    tmp = []
    for _, r in df.iterrows():
        sp, an, mo, ca = get(r,"specialty"), get(r,"anatomy"), get(r,"modality"), get(r,"category")
        if not sp: sp = "General"
        if not an: an = "General"
        
        key = f"{an} – {mo}" + (f" – {ca}" if ca else "")
        tmp.append({
            "specialty": sp, "anatomy": an, "modality_or_type": mo, "category": ca,
            "group_key": key,
            "objective": get(r,"objective"),
            "tags": get(r,"tags") or get(r,"anki_tag_string"),
            "weight_factor": safe_float(r.get(cols.get("weight_factor")), 1.0)
        })
        
    dfx = pd.DataFrame(tmp)
    groups = []
    for k, g in dfx.groupby(["specialty","anatomy","modality_or_type","category","group_key"], sort=False):
        tags = sorted(set(sum([parse_anki_tag_string(t) for t in g["tags"]], [])))
        groups.append({
            "specialty": k[0], "anatomy": k[1], "modality_or_type": k[2], "category": k[3], "group_key": k[4],
            "group_size": len(g),
            "group_weight_sum": g["weight_factor"].sum(),
            "objective_list": [x for x in g["objective"] if x],
            "tags_agg": " ".join(tags)
        })
    return pd.DataFrame(groups)

def split_group_objectives(row):
    objs = row.get("objective_list", [])
    if not objs: return []
    out = []
    chk = GROUP_MAX_OBJECTIVES
    for i, chunk in enumerate([objs[x:x+chk] for x in range(0, len(objs), chk)]):
        w = float(row.get("group_weight_sum", 0)) * (len(chunk)/len(objs))
        out.append({**row, "split_index": i, "objective_list": chunk, "group_weight_sum": w})
    return out

def process_single_group(row, provider, clients, arm="", arm_config=None):
    # Metadata
    sp, an = row["specialty"], row["anatomy"]
    mo, ca = row["modality_or_type"], row["category"]
    key = row["group_key"]
    split_idx = row.get("split_index", 0)
    
    gid = make_stable_group_id(sp, an, mo, ca, split_idx)
    tags = row["tags_agg"]
    
    # Prompt Prep
    target = compute_group_target_cards(row["group_weight_sum"])
    target = min(max(TARGET_COUNT_MIN, target), TARGET_COUNT_MAX)
    
    s1_user = PROMPT_STAGE_1_USER_GROUP.format(
        group_id=gid, specialty=sp, anatomy=an, modality_or_type=mo, category_suffix=f" > {ca}" if ca else "",
        group_key=key, split_index=split_idx, group_size=len(row["objective_list"]),
        group_weight_sum=round(row["group_weight_sum"], 2), anki_tags=tags, target_count=target,
        objective_bullets="\n".join([f"- {x}" for x in row["objective_list"]])
    )
    
    t0 = time.time()
    s1, err = call_llm(provider, clients, PROMPT_STAGE_1_SYSTEM, s1_user, 1, arm_config)
    
    base_meta = {
        "id": gid, "provider": provider, "arm": arm, "timestamp": int(t0),
        "source_info": {k: row[k] for k in ["specialty","anatomy","modality_or_type","category","group_key","split_index","tags_agg"]},
    }
    
    if not s1: return None, {"metadata": base_meta, "error": err}
    
    s1 = validate_stage1(s1, row["objective_list"][0] if row["objective_list"] else "", row["objective_list"])
    
    entities = []
    warns = []
    quota_txt, quotas = card_type_quota_lines(CARDS_PER_ENTITY, CARD_TYPE_RATIOS)
    
    for ent in s1["entity_list"][:target]:
        s2_user = PROMPT_STAGE_2_USER.format(
            master_table=s1["master_table_markdown_kr"], entity_name=ent,
            visual_type=s1["visual_type_category"], cards_per_entity=CARDS_PER_ENTITY,
            card_type_quota_lines=quota_txt
        )
        s2, err2 = call_llm(provider, clients, PROMPT_STAGE_2_SYSTEM, s2_user, 2, arm_config)
        
        if not s2:
            warns.append({"entity": ent, "error": err2})
            continue
            
        s2 = validate_stage2(s2)
        s2["anki_cards"], _ = enforce_card_quota(s2["anki_cards"], quotas)
        
        # Tagging
        base_tags = tags.split()
        for c in s2["anki_cards"]:
            c["tags"] = sorted(list(set(base_tags + c["tags"] + [f"ct_{c['card_type'].lower()}"])))
            
        entities.append(s2)
        
    if IMAGE_ASSIGN_POLICY == "RANKED_BY_IMPORTANCE":
        assign_image_necessity_by_ratio(entities, IMAGE_NECESSITY_RATIOS)
        
    return {
        "metadata": {**base_meta, "latency": round(time.time()-t0, 2), "warnings": warns},
        "meta": {"source": base_meta["source_info"], "provider": provider, "arm": arm, "run_tag": None},
        "curriculum_content": {
            "objective_summary": s1["objective_summary"],
            "master_table": s1["master_table_markdown_kr"],
            "entities": entities
        }
    }, None

# -------------------------
# Main
# -------------------------
def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--provider", default="gemini")
    parser.add_argument("--arm", choices=["A","B","C","D","E","F"], default="")
    parser.add_argument("--sample", type=int, default=0)
    parser.add_argument("--run_tag", default="")
    args = parser.parse_args()
    
    # Arm Config Override
    arm_cfg = ARM_CONFIGS.get(args.arm, {}) if args.arm else {}
    if arm_cfg: args.provider = arm_cfg["provider"]
    
    if not args.run_tag: args.run_tag = time.strftime("%Y%m%d_%H%M")

    arm_suffix = f"__arm{args.arm}" if args.arm else ""
    
    # Key Check
    pkey = MODEL_CONFIG[args.provider]["api_key_env"]
    if not os.getenv(pkey): return print(f"❌ Missing {pkey}")
    
    print(f"🚀 Arm: {args.arm} ({arm_cfg.get('label','Custom')}) | Provider: {args.provider}")
    
    # Init Clients
    clients = build_clients(args.provider, os.getenv(pkey))
    
    # Data Load
    df = pd.read_excel(INPUT_FILE)
    groups = build_groups(df)
    
    # Sampling (Simple Stratified by Physics)
    if args.sample > 0:
        phys = groups[groups["tags_agg"].str.contains("Physics|Quality", case=False)]
        rest = groups[~groups.index.isin(phys.index)]
        n_p = min(int(args.sample*0.2), len(phys))
        groups = pd.concat([phys.sample(n_p), rest.sample(args.sample-n_p)]).sample(frac=1)
    
    # Process
    out_dir = OUTPUT_DIR / "generated" / args.provider
    out_dir.mkdir(parents=True, exist_ok=True)
    fpath = out_dir / f"output_{args.provider}_{args.run_tag}{arm_suffix}.jsonl"
    
    print(f"📄 Output: {fpath}")
    
    with open(fpath, "a", encoding="utf-8") as f:
        for _, row in tqdm(groups.iterrows(), total=len(groups)):
            splits = split_group_objectives(row.to_dict())
            for s_row in splits:
                res, err = process_single_group(s_row, args.provider, clients, args.arm, arm_cfg)
                if res:
                    res["meta"]["run_tag"] = args.run_tag
                    f.write(json.dumps(res, ensure_ascii=False)+"\n")
                elif err:
                    err["meta"]["run_tag"] = args.run_tag
                    f.write(json.dumps(err, ensure_ascii=False)+"\n")
                f.flush()


    # -------------------------
    # [POST] Copy input JSONL to generated/<run_tag>/ for reproducibility
    # -------------------------
    try:
        from generated_paths import generated_run_dir
        import shutil

        run_dir = generated_run_dir(BASE_DIR, args.run_tag)
        in_dir = run_dir / "input_jsonl"
        in_dir.mkdir(parents=True, exist_ok=True)

        copied = []
        dst = in_dir / fpath.name
        if not dst.exists():
            shutil.copy2(fpath, dst)
            copied.append(str(dst))

        manifest = {
            "run_tag": args.run_tag,
            "provider": args.provider,
            "arm": args.arm,
            "source_jsonl": str(fpath),
            "copied_jsonl": copied,
            "timestamp": int(time.time()),
        }

        (run_dir / "inputs_manifest.json").write_text(
            json.dumps(manifest, ensure_ascii=False, indent=2),
            encoding="utf-8"
        )

        print(f"📌 Input JSONL copied to: {dst}")
        print(f"📌 Manifest written: {run_dir / 'inputs_manifest.json'}")

    except Exception as e:
        print(f"⚠️ Failed to write input manifest: {e}")


if __name__ == "__main__":
    main()
