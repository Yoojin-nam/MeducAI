def _is_transient_error(e: Exception) -> bool:
    name = type(e).__name__
    msg = str(e).lower()

    transient_classnames = {
        "APITimeoutError", "Timeout", "TimeoutError", "ReadTimeout", "ConnectTimeout",
        "APIConnectionError", "RateLimitError", "ServiceUnavailableError",
        "InternalServerError", "BadGatewayError", "GatewayTimeoutError",
        "DeadlineExceeded", "ResourceExhausted", "Unavailable",
    }
    if name in transient_classnames:
        return True

    transient_markers = [
        "timed out", "timeout", "rate limit", "too many requests", "temporarily unavailable",
        "service unavailable", "internal server error", "bad gateway", "gateway timeout",
        "connection aborted", "connection reset", "connection error", "tls", "502", "503", "504", "429",
    ]
    return any(m in msg for m in transient_markers)


def _raise_truncation(stage: int, provider: str, finish_reason: str | None) -> None:
    raise RuntimeError(
        f"[Stage{stage}] TruncatedOutputError: provider={provider} finish_reason={finish_reason or 'UNKNOWN'}"
    )



def call_llm(
    *,
    provider: str,
    clients: ProviderClients,
    model_name: str,
    system_prompt: str,
    user_prompt: str,
    temperature: float,
    timeout_s: int,
    stage: int,
    api_style: str,
    # Runtime logging controls
    thinking_enabled: bool,
    thinking_budget: int,
    # Debug dumping (optional)
    debug_dir: Optional[str] = None,
    debug_key: Optional[str] = None,
) -> Tuple[Optional[Dict[str, Any]], Optional[str], Dict[str, Any]]:
    """
    LLM caller with conservative transient retry and truncation hard-fail.

    Returns:
      (parsed_json | None, err | None, runtime_meta)

    runtime_meta is always returned (even on failure) and is safe to serialize.
    """
    retry_max = _env_int("LLM_RETRY_MAX", 2)
    backoff_base = _env_float("LLM_RETRY_BACKOFF_BASE_S", 2.0)
    jitter_max = _env_float("LLM_RETRY_JITTER_MAX_S", 1.0)

    max_out_stage1 = _env_int("MAX_OUTPUT_TOKENS_STAGE1", 3200)
    max_out_stage2 = _env_int("MAX_OUTPUT_TOKENS_STAGE2", 3200)
    max_out_base = max_out_stage1 if stage == 1 else max_out_stage2
    # For truncation/format failures, we may increase output budget on retry (capped).
    max_out_retry_cap = _env_int("MAX_OUTPUT_TOKENS_RETRY_CAP", 8192)
    max_out = max_out_base

    # meta container (always returned)
    meta: Dict[str, Any] = {
        "stage": stage,
        "provider": provider,
        "model": model_name,
        "api_style": (api_style or "").strip().lower(),
        "thinking_enabled": bool(thinking_enabled),
        "thinking_budget": int(thinking_budget),
        "attempts": 0,
        "latency_sec": None,
        "finish_reason": None,
        "input_tokens": None,
        "output_tokens": None,
        "total_tokens": None,
        "raw_usage": None,
        "error_class": None,
        "error_message": None,
    }

    last_err: Optional[str] = None

    for attempt in range(retry_max + 1):
        meta["attempts"] = attempt + 1
        try:
            # Stage latency should reflect the successful request attempt.
            t0 = time.perf_counter()

            if provider == "gemini":
                genai = clients.gemini
                m = genai.GenerativeModel(model_name=model_name, system_instruction=system_prompt)

                # Debug dump prompts (best-effort)
                dk = (debug_key or f"stage{stage}")
                _debug_write(debug_dir, f"{dk}__system_prompt.txt", system_prompt or "")
                _debug_write(debug_dir, f"{dk}__user_prompt.txt", user_prompt or "")

                # Optional: force JSON mime where supported (genai>=0.7 typically accepts response_mime_type)
                force_json_mime = os.environ.get("GEMINI_FORCE_JSON_MIME", "1").strip() not in {"0", "false", "False", "NO", "no"}
                gen_cfg = {"temperature": temperature, "max_output_tokens": max_out}
                if force_json_mime:
                    gen_cfg["response_mime_type"] = "application/json"

                # NOTE: google.generativeai does not expose "thinking budget" as a stable public API.
                # We log the intended budget for audit even if the provider ignores it.
                try:
                    r = m.generate_content(
                        user_prompt,
                        generation_config=gen_cfg,
                        request_options={"timeout": timeout_s},
                    )
                except TypeError:
                    # Older/strict clients may reject response_mime_type or generation_config keys.
                    gen_cfg.pop("response_mime_type", None)
                    r = m.generate_content(
                        user_prompt,
                        generation_config=gen_cfg,
                        request_options={"timeout": timeout_s},
                    )

                meta["latency_sec"] = round(time.perf_counter() - t0, 6)

                # Finish reason (best-effort)
                finish_reason = None
                try:
                    finish_reason = getattr(getattr(r, "candidates", [None])[0], "finish_reason", None)
                except Exception:
                    pass
                meta["finish_reason"] = finish_reason

                raw_text = getattr(r, "text", None) or ""
                _debug_write(debug_dir, f"{dk}__raw_response.txt", raw_text)

                try:
                    parsed = extract_json_object(raw_text)
                    return parsed, None, meta
                except Exception as e:
                    # If it looks truncated, attempt a targeted retry by increasing output tokens and tightening constraints.
                    is_trunc = _looks_truncated_json(raw_text)
                    meta["error_class"] = e.__class__.__name__
                    meta["error_message"] = str(e)
                    meta["truncation_suspected"] = bool(is_trunc)
                    _debug_write(debug_dir, f"{dk}__exception.txt", f"{e.__class__.__name__}: {e}\ntruncation_suspected={is_trunc}\n")

                    last_err = f"{e.__class__.__name__}: {e}"
                    # Prepare for retry (if any)
                    if attempt < retry_max:
                        # Increase output budget on retry (capped)
                        max_out = min(max_out_base * (attempt + 2), max_out_retry_cap)
                        # If truncation is suspected, ask for compact outputs
                        if is_trunc:
                            user_prompt = (
                                (user_prompt or "").rstrip()
                                + "\n\n[IMPORTANT]\n"
                                + "Your previous response was TRUNCATED and did not form a complete JSON object. "
                                  "Return a COMPLETE JSON object ONLY (no prose, no code fences). "
                                  "Keep long markdown fields compact: master_table_markdown_kr must be <= 20 lines; "
                                  "if longer, summarize or abbreviate. Do not include any extra keys."
                            )
                        else:
                            user_prompt = (
                                (user_prompt or "").rstrip()
                                + "\n\n[IMPORTANT]\n"
                                + "Return a COMPLETE JSON object ONLY (no prose, no code fences). "
                                  "Do not include any extra keys."
                            )
                    # Fall through to retry loop
                    raise


            if provider == "gpt":
                cli = clients.openai
                api_style_norm = (api_style or "").strip().lower()
                if api_style_norm not in {"chat", "responses"}:
                    err = f"Invalid api_style for provider=gpt: {api_style_norm} (expected chat|responses)"
                    meta["error_class"] = "ConfigError"
                    meta["error_message"] = err
                    return None, err, meta

                # "thinking" controls are provider/model dependent.
                # For audit, we always log intended values; API params are best-effort and may be ignored.
                if api_style_norm == "chat":
                    # OpenAI Chat Completions (legacy)
                    r = cli.chat.completions.create(
                        model=model_name,
                        messages=[
                            {"role": "system", "content": system_prompt},
                            {"role": "user", "content": user_prompt},
                        ],
                        response_format={"type": "json_object"},
                        temperature=temperature,
                        max_tokens=max_out,
                        timeout=timeout_s,
                    )
                    meta["latency_sec"] = round(time.perf_counter() - t0, 6)

                    # Usage (best-effort)
                    try:
                        u = getattr(r, "usage", None)
                        if u is not None:
                            meta["input_tokens"] = int(getattr(u, "prompt_tokens", None)) if getattr(u, "prompt_tokens", None) is not None else None
                            meta["output_tokens"] = int(getattr(u, "completion_tokens", None)) if getattr(u, "completion_tokens", None) is not None else None
                            meta["total_tokens"] = int(getattr(u, "total_tokens", None)) if getattr(u, "total_tokens", None) is not None else None
                            meta["raw_usage"] = {
                                "prompt_tokens": meta["input_tokens"],
                                "completion_tokens": meta["output_tokens"],
                                "total_tokens": meta["total_tokens"],
                            }
                    except Exception:
                        pass

                    finish_reason = None
                    try:
                        finish_reason = getattr(r.choices[0], "finish_reason", None)
                    except Exception:
                        finish_reason = None
                    meta["finish_reason"] = str(finish_reason) if finish_reason is not None else None

                    if meta["finish_reason"] is not None:
                        fr = str(meta["finish_reason"]).upper()
                        if "LENGTH" in fr or "MAX_TOKENS" in fr:
                            _raise_truncation(stage, provider, fr)

                    try:
                        content = r.choices[0].message.content
                    except Exception:
                        content = None
                    if not isinstance(content, str) or not content.strip():
                        err = f"[Stage{stage}] EmptyResponseError: missing message content"
                        meta["error_class"] = "EmptyResponseError"
                        meta["error_message"] = err
                        return None, err, meta
                    return extract_json_object(content), None, meta

                # OpenAI Responses API
                if not hasattr(cli, "responses"):
                    # Local SDK is likely old; fall back to chat.completions path.
                    api_style_norm = "chat"
                    # Re-enter via chat logic by raising a controlled error to retry with chat.
                    raise AttributeError("OpenAI client has no 'responses' attribute; falling back to chat")
                r = cli.responses.create(
                    model=model_name,
                    input=[
                        {"role": "system", "content": system_prompt},
                        {"role": "user", "content": user_prompt},
                    ],
                    text={"format": {"type": "json_object"}},
                    temperature=temperature,
                    max_output_tokens=max_out,
                    timeout=timeout_s,
                )
                meta["latency_sec"] = round(time.perf_counter() - t0, 6)

                # Usage (best-effort; schema differs)
                try:
                    u = getattr(r, "usage", None)
                    if u is not None:
                        # responses usage may be nested (input_tokens/output_tokens)
                        it = getattr(u, "input_tokens", None)
                        ot = getattr(u, "output_tokens", None)
                        tt = getattr(u, "total_tokens", None)
                        meta["input_tokens"] = int(it) if it is not None else None
                        meta["output_tokens"] = int(ot) if ot is not None else None
                        meta["total_tokens"] = int(tt) if tt is not None else None
                        meta["raw_usage"] = {
                            "input_tokens": meta["input_tokens"],
                            "output_tokens": meta["output_tokens"],
                            "total_tokens": meta["total_tokens"],
                        }
                except Exception:
                    pass

                # Extract output_text
                text_parts: List[str] = []
                try:
                    ot = getattr(r, "output_text", None)
                    if isinstance(ot, str) and ot.strip():
                        text_parts.append(ot)
                except Exception:
                    pass

                if not text_parts:
                    # fallback traversal
                    try:
                        for item in (getattr(r, "output", None) or []):
                            for c in (getattr(item, "content", None) or []):
                                t = getattr(c, "text", None)
                                if isinstance(t, str) and t.strip():
                                    text_parts.append(t)
                    except Exception:
                        pass

                if not text_parts:
                    err = f"[Stage{stage}] EmptyResponseError: responses output_text missing"
                    meta["error_class"] = "EmptyResponseError"
                    meta["error_message"] = err
                    return None, err, meta

                # finish_reason is not always exposed in responses; leave as None if absent
                return extract_json_object("\n".join(text_parts)), None, meta

            return None, f"[Stage{stage}] UnsupportedProvider: {provider}", meta

        except Exception as e:
            meta["error_class"] = type(e).__name__
            meta["error_message"] = str(e)

            dk = (debug_key or f"stage{stage}")
            _debug_write(debug_dir, f"{dk}__exception.txt", f"{type(e).__name__}: {e}\n")

            if _is_transient_error(e) and attempt < retry_max:
                last_err = f"[Stage{stage}] {type(e).__name__}: {e} (attempt={attempt+1}/{retry_max+1})"
                sleep_s = backoff_base * (2 ** attempt) + random.random() * jitter_max
                time.sleep(min(sleep_s, 30.0))
                continue

            return None, f"[Stage{stage}] {type(e).__name__}: {e}", meta

    return None, last_err or f"[Stage{stage}] UnknownError: retry loop exhausted", meta


