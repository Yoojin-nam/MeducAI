TABLE_INFOGRAPHIC_CONSTRAINTS = (
    "Single-page educational infographic, white background, high contrast, minimal text (labels only), "
    "no watermark, clinically accurate."
)


def validate_stage1(stage1: Dict[str, Any], fallback_summary: str) -> Dict[str, Any]:
    s = dict(stage1 or {})

    s.setdefault("objective_summary", fallback_summary)
    s.setdefault("group_objectives", [])
    s.setdefault("visual_type_category", "General")
    s.setdefault("master_table_markdown_kr", "")
    s.setdefault("entity_list", [])
    s.setdefault("table_infographic_style", "Default")
    s.setdefault("table_infographic_keywords_en", fallback_summary)
    s.setdefault("table_infographic_prompt_en", "")

    mt = str(s.get("master_table_markdown_kr") or "").strip()
    if not mt or len(mt) < 10:
        mt = f"| Concept | Summary |\n|---|---|\n| **Overview** | {fallback_summary} |"
    s["master_table_markdown_kr"] = mt

    prompt = str(s.get("table_infographic_prompt_en") or "").strip()
    if not prompt:
        kw = str(s.get("table_infographic_keywords_en") or fallback_summary).strip() or fallback_summary
        prompt = f"Educational medical infographic about {kw}. {TABLE_INFOGRAPHIC_CONSTRAINTS}"
    s["table_infographic_prompt_en"] = prompt

    ent = s.get("entity_list")
    if not isinstance(ent, list):
        ent = []
    ent = [str(x).strip() for x in ent if str(x).strip()]
    s["entity_list"] = ent

    return s


def validate_stage2(stage2: Dict[str, Any]) -> Dict[str, Any]:
    s_in = dict(stage2 or {})

    out: Dict[str, Any] = {}
    if "group_id" in s_in and s_in["group_id"] is not None:
        out["group_id"] = str(s_in["group_id"])
    out["entity_name"] = str(s_in.get("entity_name") or "Unnamed entity").strip()

    cards = s_in.get("anki_cards") or []
    if not isinstance(cards, list):
        cards = []
    norm_cards: List[Dict[str, Any]] = []
    for c in cards:
        if not isinstance(c, dict):
            continue
        cc = {
            "card_type": str(c.get("card_type") or "Basic").strip(),
            "front": str(c.get("front") or "").strip(),
            "back": str(c.get("back") or "").strip(),
            "tags": str(c.get("tags") or "").strip(),
        }
        if not (cc["front"] and cc["back"]):
            continue
        norm_cards.append(cc)

    out["anki_cards"] = norm_cards
    return out


