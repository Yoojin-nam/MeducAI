def _looks_truncated_json(raw: str) -> bool:
    raw = (raw or "").strip()
    if not raw:
        return False
    # If it starts like JSON but does not contain a closing brace, it is likely truncated.
    if raw.startswith("{") and ("}" not in raw):
        return True
    # If braces are imbalanced, likely truncated.
    try:
        return raw.count("{") > raw.count("}")
    except Exception:
        return False

